                      "value": "percent"
                    },
                    {
                      "id": "custom.axisLabel",
                      "value": "%"
                    },
                    {
                      "id": "custom.axisPlacement",
                      "value": "right"
                    },
                    {
                      "id": "color",
                      "value": {
                        "fixedColor": "blue",
                        "mode": "fixed"
                      }
                    }
