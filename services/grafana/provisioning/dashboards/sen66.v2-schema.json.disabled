              "overrides": [
                {
                  "matcher": {
                    "id": "byName",
                    "options": "temperature"
                  },
                  "properties": [
                    {
                      "id": "unit",
                      "value": "celsius"
                    },
                    {
                      "id": "custom.axisLabel",
                      "value": "°C"
                    },
