# ─────────────────────────────────────────────────────────────────────────────
# savage – environment variable template
#
# Copy this file to .env and fill in real values.
# .env is git-ignored; NEVER commit credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Timezone (tz database name, e.g. America/New_York) ───────────────────────
TZ=UTC

# ── InfluxDB ──────────────────────────────────────────────────────────────────
# Admin username + password (used for the InfluxDB UI and CLI)
INFLUX_USER=admin
INFLUX_PASS=changeme00

# Organisation and default bucket for SEN66 time-series data
INFLUX_ORG=savage
INFLUX_BUCKET=timeseries

# Static API token — set once at init, reused by Node-RED and Grafana.
# Change this to any long random string before deploying.
INFLUX_TOKEN=savage-influx-token

# Internal Docker network URL (do not change unless you rename the service)
INFLUX_URL=http://influxdb:8086

# ── Grafana admin credentials (change after first login) ─────────────────────
GRAFANA_USER=admin
GRAFANA_PASS=admin

# ── MQTT (Mosquitto) ─────────────────────────────────────────────────────────
# These get hashed into services/mosquitto/config/passwd by `make dev`.
# Sensor devices (Pico W) must use these same credentials in their config.py.
MQTT_USER=mqttuser
MQTT_PASS=mqttpass
